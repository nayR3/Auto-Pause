{
    "geode": "4.10.0",
    "gd": {
        "win": "2.2074",
        "mac": "2.2074",
        "android": "2.2074",
        "ios": "2.2074"
    },
    "id": "nayr.auto-pause",
    "name": "Auto Pause",
    "version": "1.0.1",
    "developer": "nayR",
    "description": "aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa",
	"dependencies": {
        "geode.custom-keybinds": {
            "id": "geode.custom-keybinds",
            "version": "v1.1.0",
            "importance": "required"
        }
	},
    "settings": {
		"title-setting-example": {
		"type": "title",
		"name": "Go to settings > options > keys to set keybind."
	},
		"muteP": {
    		"type": "float",
			"name": "Mute Percentage",
			"description": "What percent to mute background media at.",
			"default": 40.0,
			"min": 0.0,
			"max": 100.0,
			"control": {
				"arrows": false,
				"arrow-step": 0.1,
				"big-arrows": false,
				"big-arrow-step": 0.5,
				"slider": true,
				"slider-step": 0.1,
				"input": true
			}
		},
		"media-app": {
			"type": "path",
			"name": "Media / Call App",
			"description": "Executable to send pause/unpause keys to",
			"default": "C:/Program Files/Firefox Developer Edition/firefox.exe",
			"control": {
				"dialog": "open",
				"filters": [
					{
						"files": ["*.exe", "*.so", "*.dmg"],
						"description": "Executable programs"
					}
				]
			}
		}
	}
}
